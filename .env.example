# Copy this file to .env for local development.
# Do not put real production secrets in this repository.

POSTGRES_DB=internship_pipeline
POSTGRES_USER=internship
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://internship:change-me-local-only@postgres:5432/internship_pipeline
REDIS_URL=redis://redis:6379/0

BACKEND_PORT=8000
FRONTEND_PORT=3000
N8N_PORT=5678

CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://backend:8000

N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=local-admin
N8N_BASIC_AUTH_PASSWORD=change-me-local-only
N8N_ENCRYPTION_KEY=replace-with-a-local-random-string

# ── JARVIS / Telegram ─────────────────────────────────────────────────────────
JARVIS_TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Outreach (email delivery) ─────────────────────────────────────────────────
# Get a free key at https://resend.com — required to actually send emails.
# When absent, outreach/send runs in dry-run mode (status=sent, no real email).
RESEND_API_KEY=

# ── People Finder enrichers (all optional — stubs work without them) ──────────
# GitHub: Personal Access Token at https://github.com/settings/tokens
GITHUB_TOKEN=
# Apollo.io: key from https://app.apollo.io/settings/integrations/api
APOLLO_API_KEY=
# LinkedIn via Apify: key from https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# ── Deploy webhook (used by .github/workflows/deploy.yml) ────────────────────
# Configure these as GitHub repo secrets (Actions > Secrets), not here.
# DEPLOY_WEBHOOK_URL=https://your-server/hooks/deploy
# DEPLOY_WEBHOOK_SECRET=replace-with-random-secret
