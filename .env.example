# Copy this file to .env for local development.
# Do not put real production secrets in this repository.

POSTGRES_DB=internship_pipeline
POSTGRES_USER=internship
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://internship:change-me-local-only@postgres:5432/internship_pipeline
REDIS_URL=redis://redis:6379/0

BACKEND_PORT=8000
FRONTEND_PORT=3000
N8N_PORT=5678

CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://backend:8000

N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=local-admin
N8N_BASIC_AUTH_PASSWORD=change-me-local-only
N8N_ENCRYPTION_KEY=replace-with-a-local-random-string
